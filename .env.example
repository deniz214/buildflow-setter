# Copy this file to ".env" and fill in the two values from your MAIN app.
# They're the same Supabase project, so the setter app reads the same data.
# Find them in your main app's .env, or in Netlify → main site → Environment variables.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
